{
  "name": "karbone-k",
  "version": "1.0.0",
  "description": "Karboneʞ - Fullstack Event Management Platform",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "cd backend && npm run dev",
    "start": "cd backend && npm start",
